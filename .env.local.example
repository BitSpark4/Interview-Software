# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is in .gitignore.

# ── Supabase ────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Claude API ──────────────────────────────────────────────
VITE_CLAUDE_API_KEY=sk-ant-api03-your-key-here

# ── Razorpay (use test keys for dev, live keys for production)
# Get from: https://dashboard.razorpay.com/app/keys
VITE_RAZORPAY_TEST_API_KEY=rzp_test_your_key_here
VITE_RAZORPAY_TEST_SECRET_KEY=your_razorpay_test_secret_here
